# Препоръчително: няколко ключа за key rotation (разделени със запетая).
# При изчерпване на текущия ключ, инструментът автоматично превключва на
# следващия — работи само ако ключовете са от РАЗЛИЧНИ Google Cloud проекти
# (иначе делят една и съща квота).
YOUTUBE_API_KEYS=key1_here,key2_here,key3_here

# Или само един ключ (обратна съвместимост) — ползва се само ако
# YOUTUBE_API_KEYS липсва по-горе.
# YOUTUBE_API_KEY=your_api_key_here
