{
  "manifest_version": 3,
  "name": "YouTube High-Interest Filter",
  "version": "1.0.0",
  "description": "Filters YouTube search results: no Shorts, established channels only, high views/subscribers ratio, with automatic date-range fallback.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.googleapis.com/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Filter — settings",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
